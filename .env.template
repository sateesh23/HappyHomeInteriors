# Happy Home Interiors — Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase (get from supabase.com → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key (for admin operations — keep SECRET, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Admin Panel Password (change this to a strong password in production)
ADMIN_PASSWORD=
